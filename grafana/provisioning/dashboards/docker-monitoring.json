{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Visão geral do host",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "CPU do host",
      "type": "gauge",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [{
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU"
      }]
    },
    {
      "title": "Memória do host",
      "type": "gauge",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [{
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "RAM"
      }]
    },
    {
      "title": "Disco do host",
      "type": "gauge",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [{
        "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"rootfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"rootfs\"})) * 100",
        "legendFormat": "Disco"
      }]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{
        "expr": "time() - node_boot_time_seconds",
        "legendFormat": "Uptime"
      }]
    },
    {
      "title": "Memória total / disponível",
      "type": "stat",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 7 },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Disponível" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes", "legendFormat": "Total" },
        { "expr": "node_memory_MemAvailable_bytes", "legendFormat": "Disponível" }
      ]
    },
    {
      "title": "Containers rodando",
      "type": "stat",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "purple", "value": null }] }
        }
      },
      "targets": [{
        "expr": "count(container_memory_usage_bytes{name!=\"\"} > 0)",
        "legendFormat": "Containers"
      }]
    },
    {
      "title": "Tráfego total de rede",
      "type": "stat",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": { "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "targets": [{
        "expr": "sum(rate(container_network_receive_bytes_total{name!=\"\"}[5m])) + sum(rate(container_network_transmit_bytes_total{name!=\"\"}[5m]))",
        "legendFormat": "Total"
      }]
    },
    {
      "title": "CPU por container",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "collapsed": false
    },
    {
      "title": "Uso de CPU por container (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "fillOpacity": 15, "lineWidth": 2, "spanNulls": true }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [{
        "expr": "sum(rate(container_cpu_usage_seconds_total{name!=\"\"}[5m])) by (name) * 100",
        "legendFormat": "{{name}}"
      }]
    },
    {
      "title": "Memória por container",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },
    {
      "title": "Uso de memória por container",
      "type": "timeseries",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 15, "lineWidth": 2, "spanNulls": true }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [{
        "expr": "container_memory_usage_bytes{name!=\"\"}",
        "legendFormat": "{{name}}"
      }]
    },
    {
      "title": "Top 10 - Memória (atual)",
      "type": "bargauge",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 22 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 268435456 },
              { "color": "red", "value": 536870912 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{
        "expr": "topk(10, container_memory_usage_bytes{name!=\"\"})",
        "legendFormat": "{{name}}"
      }]
    },
    {
      "title": "Rede por container",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false
    },
    {
      "title": "Download (RX) por container",
      "type": "timeseries",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": true }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [{
        "expr": "sum(rate(container_network_receive_bytes_total{name!=\"\"}[5m])) by (name)",
        "legendFormat": "{{name}}"
      }]
    },
    {
      "title": "Upload (TX) por container",
      "type": "timeseries",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": true }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [{
        "expr": "sum(rate(container_network_transmit_bytes_total{name!=\"\"}[5m])) by (name)",
        "legendFormat": "{{name}}"
      }]
    },
    {
      "title": "Disco I/O por container",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "collapsed": false
    },
    {
      "title": "Leitura de disco por container",
      "type": "timeseries",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "expr": "sum(rate(container_fs_reads_bytes_total{name!=\"\"}[5m])) by (name)",
        "legendFormat": "{{name}}"
      }]
    },
    {
      "title": "Escrita de disco por container",
      "type": "timeseries",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [{
        "expr": "sum(rate(container_fs_writes_bytes_total{name!=\"\"}[5m])) by (name)",
        "legendFormat": "{{name}}"
      }]
    },
    {
      "title": "Alertas ativos",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": false
    },
    {
      "title": "Alertas do Prometheus",
      "type": "alertlist",
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 50 },
      "options": {
        "showOptions": "current",
        "maxItems": 10,
        "sortOrder": 1,
        "stateFilter": { "firing": true, "pending": true, "noData": false, "normal": false }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["docker", "monitoring", "coolify"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "America/Belem",
  "title": "Docker Containers - Monitoramento",
  "uid": "docker-monitoring-coolify",
  "version": 1
}
